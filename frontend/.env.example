# Copy to .env.local — never commit to git.

# Backend URL (leave blank to use the default in src/api/client.js)
REACT_APP_API_URL=https://hotel-reservation-system-backend-aeqb.onrender.com

# Stripe publishable key (safe to expose — this is the PUBLIC key)
# Get from: dashboard.stripe.com → Developers → API keys → Publishable key
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
