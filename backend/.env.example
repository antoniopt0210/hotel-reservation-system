# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Flask
FLASK_ENV=development
SECRET_KEY=replace-with-a-random-string

# JWT
JWT_SECRET_KEY=replace-with-another-random-string

# PostgreSQL (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Cassandra / DataStax Astra
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...
ASTRA_DB_KEYSPACE=default_keyspace

# Stripe — get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Also set REACT_APP_STRIPE_PUBLISHABLE_KEY in frontend/.env

# Email — SendGrid SMTP
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG....          # SendGrid API key
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# Redis — Upstash → your database → REST URL (use the rediss:// connection string)
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# Background scheduler (set to true on ONE Render instance only)
ENABLE_SCHEDULER=false
